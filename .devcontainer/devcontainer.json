{
  "name": "Feltee Dev",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/var/www/html",
  "forwardPorts": [8080, 3306],
  "portsAttributes": {
    "8080": { "label": "Apache", "onAutoForward": "openBrowser" },
    "3306": { "label": "MySQL" }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "bmewburn.vscode-intelephense-client",
        "xdebug.php-debug",
        "mtxr.sqltools",
        "mtxr.sqltools-driver-mysql"
      ]
    }
  },
  "postCreateCommand": "echo 'Dev container ready. Site at http://localhost:8080'"
}
