SITE_URL=https://example.com
DB_HOST=localhost
DB_PORT=3306
DB_NAME=your_database
DB_USER=your_username
DB_PASS=your_password

# PayU Payment Gateway
# Use sandbox for testing: https://secure.snd.payu.com
# Use production: https://secure.payu.com
PAYU_POS_ID=POS_ID_FROM_PAYU
PAYU_MD5_KEY=MD5_KEY_FROM_PAYU
PAYU_CLIENT_ID=CLIENT_ID_FROM_PAYU
PAYU_CLIENT_SECRET=CLIENT_SECRET_FROM_PAYU
PAYU_BASE_URL=PAYU_BASE_URL

# InPost ShipX API
# Use sandbox for testing: https://sandbox-api-shipx-pl.easypack24.net
# Use production: https://api-shipx-pl.easypack24.net
INPOST_API_TOKEN=your_inpost_api_token
INPOST_ORG_ID=your_organization_id
INPOST_BASE_URL=https://sandbox-api-shipx-pl.easypack24.net
INPOST_GEOWIDGET_TOKEN=your_geowidget_token
